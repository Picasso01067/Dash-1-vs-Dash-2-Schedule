<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BSIT Schedule – First Semester</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;700&display=swap');

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #0f1117;
    --surface: #1a1d27;
    --border: #2a2d3e;
    --accent-21: #5b8dee;
    --accent-22: #e85d75;
    --text: #e8eaf0;
    --muted: #7b7f95;
    --label: #b0b4cc;
    --mon: #1e2235;
    --tue: #1e2235;
    --wed: #1e2235;
    --thu: #1e2235;
    --fri: #1e2235;
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Inter', sans-serif;
    min-height: 100vh;
    padding: 24px 16px 48px;
  }

  header {
    text-align: center;
    margin-bottom: 32px;
  }

  header h1 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.6rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
  }

  header p {
    color: var(--muted);
    font-size: 0.85rem;
    margin-top: 4px;
  }

  .legend {
    display: flex;
    gap: 20px;
    justify-content: center;
    margin-bottom: 28px;
    flex-wrap: wrap;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.8rem;
    color: var(--label);
    font-weight: 500;
  }

  .dot {
    width: 12px; height: 12px;
    border-radius: 3px;
  }

  .dot-21 { background: var(--accent-21); }
  .dot-22 { background: var(--accent-22); }

  /* ── SECTION TABS ── */
  .tabs {
    display: flex;
    gap: 8px;
    justify-content: center;
    margin-bottom: 28px;
  }

  .tab {
    padding: 8px 20px;
    border-radius: 20px;
    border: 1.5px solid var(--border);
    background: transparent;
    color: var(--muted);
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    font-family: 'Inter', sans-serif;
    transition: all 0.2s;
  }

  .tab.active-21, .tab:hover { color: var(--text); }
  .tab.active-21 { border-color: var(--accent-21); background: rgba(91,141,238,0.12); color: var(--accent-21); }
  .tab.active-22 { border-color: var(--accent-22); background: rgba(232,93,117,0.12); color: var(--accent-22); }

  /* ── GRID ── */
  .schedule-grid {
    display: none;
    max-width: 680px;
    margin: 0 auto;
  }
  .schedule-grid.visible { display: block; }

  .day-block {
    margin-bottom: 12px;
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }

  .day-header {
    padding: 10px 16px;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: var(--surface);
    color: var(--muted);
    border-bottom: 1px solid var(--border);
  }

  .class-row {
    display: grid;
    grid-template-columns: 110px 1fr auto;
    gap: 12px;
    align-items: start;
    padding: 12px 16px;
    border-bottom: 1px solid var(--border);
    transition: background 0.15s;
  }

  .class-row:last-child { border-bottom: none; }
  .class-row:hover { background: rgba(255,255,255,0.03); }

  .time-badge {
    font-size: 0.72rem;
    font-weight: 600;
    padding: 4px 8px;
    border-radius: 6px;
    line-height: 1.4;
    text-align: center;
    white-space: nowrap;
  }

  .time-21 { background: rgba(91,141,238,0.18); color: var(--accent-21); }
  .time-22 { background: rgba(232,93,117,0.18); color: var(--accent-22); }

  .class-name {
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--text);
    line-height: 1.4;
  }

  .class-code {
    font-size: 0.7rem;
    color: var(--muted);
    margin-top: 2px;
  }

  .room-badge {
    font-size: 0.68rem;
    font-weight: 600;
    color: var(--muted);
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 3px 7px;
    border-radius: 5px;
    white-space: nowrap;
    align-self: center;
  }

  .empty-day {
    padding: 12px 16px;
    font-size: 0.78rem;
    color: var(--muted);
    font-style: italic;
  }

  /* ── SUMMARY TABLE ── */
  .summary {
    max-width: 680px;
    margin: 32px auto 0;
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }

  .summary-header {
    padding: 12px 16px;
    background: var(--surface);
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    border-bottom: 1px solid var(--border);
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.78rem;
  }

  th {
    padding: 9px 16px;
    text-align: left;
    font-weight: 600;
    color: var(--muted);
    background: var(--surface);
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    border-bottom: 1px solid var(--border);
  }

  td {
    padding: 10px 16px;
    color: var(--label);
    border-bottom: 1px solid var(--border);
    vertical-align: top;
    line-height: 1.5;
  }

  tr:last-child td { border-bottom: none; }
  tr:hover td { background: rgba(255,255,255,0.02); }

  td:first-child { color: var(--text); font-weight: 500; }

  .sched-21 { color: var(--accent-21); }
  .sched-22 { color: var(--accent-22); }

  .total-row td {
    font-weight: 700;
    color: var(--text);
    background: rgba(255,255,255,0.03);
    border-top: 1px solid var(--border);
  }
</style>
</head>

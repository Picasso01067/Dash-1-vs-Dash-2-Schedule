<script>
  function show(section) {
    document.querySelectorAll('.schedule-grid').forEach(g => g.classList.remove('visible'));
    document.querySelectorAll('.tab').forEach(t => { t.className = 'tab'; });
    document.getElementById('grid-' + section).classList.add('visible');
    const btn = [...document.querySelectorAll('.tab')].find(t => t.textContent.includes('2-' + section.slice(-1)));
    if (btn) btn.classList.add('active-' + section);
  }
  // init
  document.querySelectorAll('.tab')[0].classList.add('active-21');
</script>
